{
  "name": "news-fragments",
  "version": "4.2.0",
  "description": "A release-it plugin to manipulate changelogs",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "pretest": "npm run lint:fix",
    "test": "npx vitest --run --coverage",
    "test:ui": "npx vitest --ui",
    "lint": "eslint *.js --ignore-pattern node_modules/",
    "lint:fix": "eslint *.js --fix --ignore-pattern node_modules/",
    "release": "release-it"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/grupoboticario/news-fragments.git"
  },
  "keywords": [
    "release",
    "release-it",
    "release-it-plugin",
    "changelog",
    "grupoboticario"
  ],
  "author": "Grupo Boticário",
  "license": "Unlicense",
  "bugs": {
    "url": "https://github.com/grupoboticario/news-fragments/issues"
  },
  "homepage": "https://github.com/grupoboticario/news-fragments#readme",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@release-it/bumper": "^7.0.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "fs-monkey": "^1.1.0",
    "globals": "^17.5.0",
    "memfs": "^4.57.2",
    "mockdate": "^3.0.5",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "semver": "^7.7.4",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "chalk-template": "^1.1.2",
    "handlebars": "^4.7.9",
    "joi": "^18.1.2",
    "marked": "^18.0.2",
    "marked-terminal": "^7.3.0",
    "meow": "^14.1.0",
    "moment": "^2.30.1",
    "release-it": "^20.0.1"
  },
  "engines": {
    "npm": ">=10",
    "node": ">=22"
  },
  "release-it": {
    "npm": false,
    "hooks": {
      "before:init": "npm test",
      "after:bump": "node myself-release.js"
    },
    "plugins": {
      "@release-it/bumper": {
        "out": [
          {
            "file": "sonar-project.properties",
            "type": "text/x-properties",
            "path": "sonar.projectVersion"
          },
          {
            "file": "package.json",
            "path": "version"
          }
        ]
      }
    }
  },
  "bin": {
    "news-fragments": "src/cli/index.js"
  }
}
